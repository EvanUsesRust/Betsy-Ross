const unsigned int TOTAL_STEPS = 2097;

// ── Servos ────────────────────────────────────────────────────────────────────
Servo mouth, lidLeft, lidRight, eyeLeft, eyeRight;

// ── Eye state ─────────────────────────────────────────────────────────────────
float currentEyePos  = EYE_CENTER;
float targetEyePos   = EYE_CENTER;
float eyeVelocity    = 0.0;

// ── Blink state ───────────────────────────────────────────────────────────────
enum BlinkState { BLINK_IDLE, BLINK_CLOSING, BLINK_HOLDING, BLINK_OPENING };
BlinkState blinkState    = BLINK_IDLE;
int        blinkStep     = 0;
unsigned long blinkTimer = 0;

// ── Mouth state ───────────────────────────────────────────────────────────────
unsigned int  mouthIndex    = 0;
unsigned long lastMouthStep = 0;
bool          mouthDone     = false;

// ── Timing ────────────────────────────────────────────────────────────────────
unsigned long lastBlinkTime  = 0;
unsigned long nextBlinkDelay = 0;
unsigned long lastEyeUpdate  = 0;

// ── Simple PRNG ───────────────────────────────────────────────────────────────
unsigned long randSeed = 12345;
unsigned long nextRand() {
  randSeed = randSeed * 1664525UL + 1013904223UL;
  return randSeed;
}
int randRange(int lo, int hi) {
  return lo + (int)(nextRand() % (unsigned long)(hi - lo + 1));
}

// ─────────────────────────────────────────────────────────────────────────────

void setup() {
  mouth.attach(PIN_MOUTH);
  lidLeft.attach(PIN_LID_LEFT);
  lidRight.attach(PIN_LID_RIGHT);
  eyeLeft.attach(PIN_EYE_LEFT);
  eyeRight.attach(PIN_EYE_RIGHT);

  mouth.write(MOUTH_CLOSED);
  lidLeft.write(LID_LEFT_OPEN);
  lidRight.write(LID_RIGHT_OPEN);
  eyeLeft.write(EYE_CENTER);
  eyeRight.write(EYE_CENTER);

  delay(500);

  lastMouthStep  = millis();
  lastBlinkTime  = millis();
  nextBlinkDelay = randRange(BLINK_INTERVAL_MIN, BLINK_INTERVAL_MAX);
  lastEyeUpdate  = millis();
}

void loop() {
  unsigned long now = millis();

  // ── Mouth playback ──────────────────────────────────────────────────────────
  if (!mouthDone && now - lastMouthStep >= MOUTH_INTERVAL_MS) {
    lastMouthStep = now;
    uint8_t angle = pgm_read_byte(&ANGLES[mouthIndex]);
    mouth.write(angle);
    mouthIndex++;
    if (mouthIndex >= TOTAL_STEPS) {
      mouth.write(MOUTH_CLOSED);
      mouthDone = true;
    }
  }

  // ── Eye wander ──────────────────────────────────────────────────────────────
  if (now - lastEyeUpdate >= EYE_UPDATE_MS) {
    lastEyeUpdate = now;

    if ((nextRand() % 100) < 2) {
      if ((float)(nextRand() % 100) / 100.0 < CENTER_BIAS) {
        targetEyePos = EYE_CENTER + randRange(-8, 8);
      } else {
        targetEyePos = EYE_CENTER + randRange(-WANDER_RANGE, WANDER_RANGE);
      }
      if (targetEyePos < EYE_FULL_LEFT)  targetEyePos = EYE_FULL_LEFT;
      if (targetEyePos > EYE_FULL_RIGHT) targetEyePos = EYE_FULL_RIGHT;
    }

    float diff = targetEyePos - currentEyePos;
    eyeVelocity   = eyeVelocity * 0.7 + diff * 0.06;
    currentEyePos += eyeVelocity;
    if (currentEyePos < EYE_FULL_LEFT)  currentEyePos = EYE_FULL_LEFT;
    if (currentEyePos > EYE_FULL_RIGHT) currentEyePos = EYE_FULL_RIGHT;

    eyeLeft.write((int)currentEyePos);
    eyeRight.write((int)currentEyePos);
  }

  // ── Blink state machine ─────────────────────────────────────────────────────
  switch (blinkState) {

    case BLINK_IDLE:
      if (now - lastBlinkTime >= nextBlinkDelay) {
        blinkState = BLINK_CLOSING;
        blinkStep  = 0;
        blinkTimer = now;
      }
      break;

    case BLINK_CLOSING:
      if (now - blinkTimer >= (unsigned long)(BLINK_CLOSE_MS / BLINK_STEPS)) {
        blinkTimer = now;
        int lAngle = map(blinkStep, 0, BLINK_STEPS, LID_LEFT_OPEN,  LID_LEFT_CLOSED);
        int rAngle = map(blinkStep, 0, BLINK_STEPS, LID_RIGHT_OPEN, LID_RIGHT_CLOSED);
        lidLeft.write(lAngle);
        lidRight.write(rAngle);
        blinkStep++;
        if (blinkStep > BLINK_STEPS) {
          blinkState = BLINK_HOLDING;
          blinkTimer = now;
        }
      }
      break;

    case BLINK_HOLDING:
      if (now - blinkTimer >= BLINK_HOLD_MS) {
        blinkState = BLINK_OPENING;
        blinkStep  = 0;
        blinkTimer = now;
      }
      break;

    case BLINK_OPENING:
      if (now - blinkTimer >= (unsigned long)(BLINK_OPEN_MS / BLINK_STEPS)) {
        blinkTimer = now;
        int lAngle = map(blinkStep, 0, BLINK_STEPS, LID_LEFT_CLOSED,  LID_LEFT_OPEN);
        int rAngle = map(blinkStep, 0, BLINK_STEPS, LID_RIGHT_CLOSED, LID_RIGHT_OPEN);
        lidLeft.write(lAngle);
        lidRight.write(rAngle);
        blinkStep++;
        if (blinkStep > BLINK_STEPS) {
          blinkState     = BLINK_IDLE;
          lastBlinkTime  = now;
          nextBlinkDelay = randRange(BLINK_INTERVAL_MIN, BLINK_INTERVAL_MAX);
        }
      }
      break;
  }
}
